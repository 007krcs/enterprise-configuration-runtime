    "product": {
      "version": "1.0.0",
      "pageId": "product",
      "layout": {
        "id": "product-root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "product-header",
            "type": "section",
            "title": "Product Details",
            "componentIds": ["productName", "productPrice", "productDescription"]
          },
          {
            "id": "product-stock",
            "type": "section",
            "title": "Availability",
            "componentIds": ["stockIndicator"]
          },
          {
            "id": "product-actions",
            "type": "section",
            "title": "Actions",
            "componentIds": ["addToCartButton"]
          }
        ]
      },
      "components": [
        {
          "id": "productName",
          "type": "text",
          "adapterHint": "platform.alert",
          "props": {
            "title": "Product Name",
            "intent": "primary"
          },
          "bindings": {
            "data": {
              "value": "data.product.name"
            }
          },
          "i18n": {
            "labelKey": "ecr.product.name"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.product.name.aria",
            "tabIndex": 0,
            "role": "heading",
            "keyboardNav": true,
            "focusOrder": 1
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 8 }
            }
          }
        },
        {
          "id": "productPrice",
          "type": "text",
          "adapterHint": "platform.badge",
          "props": {
            "label": "$0.00"
          },
          "bindings": {
            "data": {
              "value": "data.product.price"
            }
          },
          "i18n": {
            "labelKey": "ecr.product.price"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.product.price.aria",
            "tabIndex": 0,
            "role": "status",
            "keyboardNav": true,
            "focusOrder": 2
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 4 }
            }
          }
        },
        {
          "id": "productDescription",
          "type": "text",
          "adapterHint": "platform.alert",
          "props": {
            "title": "Description",
            "description": "Product description will appear here",
            "intent": "neutral"
          },
          "bindings": {
            "data": {
              "value": "data.product.description"
            }
          },
          "i18n": {
            "labelKey": "ecr.product.description"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.product.description.aria",
            "tabIndex": 0,
            "role": "region",
            "keyboardNav": true,
            "focusOrder": 3
          }
        },
        {
          "id": "stockIndicator",
          "type": "text",
          "adapterHint": "platform.chip",
          "props": {
            "label": "In Stock"
          },
          "bindings": {
            "data": {
              "value": "data.product.stockStatus"
            }
          },
          "i18n": {
            "labelKey": "ecr.product.stock"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.product.stock.aria",
            "tabIndex": 0,
            "role": "status",
            "keyboardNav": true,
            "focusOrder": 4
          }
        },
        {
          "id": "addToCartButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Add to Cart",
            "variant": "solid",
            "intent": "primary",
            "size": "lg"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onAddToCart" } }
            ]
          },
          "i18n": {
            "labelKey": "ecr.product.addToCart"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.product.addToCart.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 5
          }
        }
      ]
    },
    "cart": {
      "version": "1.0.0",
      "pageId": "cart",
      "layout": {
        "id": "cart-root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "cart-items-section",
            "type": "section",
            "title": "Your Cart",
            "componentIds": ["cartItemsTable"]
          },
          {
            "id": "cart-totals-section",
            "type": "section",
            "title": "Cart Summary",
            "componentIds": ["cartTotalText"]
          },
          {
            "id": "cart-discount-section",
            "type": "section",
            "title": "Discount",
            "componentIds": ["discountInput", "applyDiscountButton"]
          },
          {
            "id": "cart-actions-section",
            "type": "section",
            "title": "Actions",
            "componentIds": ["proceedToCheckoutButton"]
          }
        ]
      },
      "components": [
        {
          "id": "cartItemsTable",
          "type": "table",
          "adapterHint": "aggrid.table",
          "props": {
            "columns": [
              { "field": "name", "headerKey": "ecr.cart.item.name" },
              { "field": "quantity", "headerKey": "ecr.cart.item.quantity" },
              { "field": "unitPrice", "headerKey": "ecr.cart.item.unitPrice" },
              { "field": "subtotal", "headerKey": "ecr.cart.item.subtotal" }
            ],
            "rows": []
          },
          "bindings": {
            "data": {
              "rows": "data.cart.items"
            }
          },
          "i18n": {
            "labelKey": "ecr.cart.items.table"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.cart.items.table.aria",
            "tabIndex": 0,
            "role": "table",
            "keyboardNav": true,
            "focusOrder": 1
          }
        },
        {
          "id": "cartTotalText",
          "type": "text",
          "adapterHint": "platform.alert",
          "props": {
            "title": "Cart Total",
            "description": "$0.00",
            "intent": "primary"
          },
          "bindings": {
            "data": {
              "value": "data.cart.total"
            }
          },
          "i18n": {
            "labelKey": "ecr.cart.total"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.cart.total.aria",
            "tabIndex": 0,
            "role": "status",
            "keyboardNav": true,
            "focusOrder": 2
          }
        },
        {
          "id": "discountInput",
          "type": "input",
          "adapterHint": "platform.textField",
          "props": {
            "label": "Discount Code",
            "placeholder": "Enter discount code"
          },
          "bindings": {
            "data": {
              "value": "data.cart.discountCode"
            }
          },
          "i18n": {
            "labelKey": "ecr.cart.discount.label",
            "placeholderKey": "ecr.cart.discount.placeholder",
            "helperTextKey": "ecr.cart.discount.helper"
          },
          "validations": {
            "required": false,
            "max": 32
          },
          "accessibility": {
            "ariaLabelKey": "ecr.cart.discount.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 3
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 8 }
            }
          }
        },
        {
          "id": "applyDiscountButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Apply Discount",
            "variant": "outline",
            "intent": "secondary",
            "size": "md"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onApplyDiscount" } }
            ]
          },
          "i18n": {
            "labelKey": "ecr.cart.applyDiscount"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.cart.applyDiscount.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 4
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 4 }
            }
          }
        },
        {
          "id": "proceedToCheckoutButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Proceed to Checkout",
            "variant": "solid",
            "intent": "primary",
            "size": "lg"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onCheckout" } }
            ]
          },
          "i18n": {
            "labelKey": "ecr.cart.checkout"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.cart.checkout.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 5
          }
        }
      ]
    },
    "checkout": {
      "version": "1.0.0",
      "pageId": "checkout",
      "layout": {
        "id": "checkout-root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "checkout-shipping-section",
            "type": "section",
            "title": "Shipping Address",
            "componentIds": ["shippingAddressInput", "shippingCityInput", "shippingPostalCodeInput"]
          },
          {
            "id": "checkout-payment-section",
            "type": "section",
            "title": "Payment",
            "componentIds": ["paymentMethodSelect"]
          },
          {
            "id": "checkout-actions-section",
            "type": "section",
            "title": "Actions",
            "componentIds": ["placeOrderButton"]
          }
        ]
      },
      "components": [
        {
          "id": "shippingAddressInput",
          "type": "input",
          "adapterHint": "platform.textField",
          "props": {
            "label": "Street Address",
            "placeholder": "Enter your street address"
          },
          "bindings": {
            "data": {
              "value": "data.checkout.shipping.address"
            }
          },
          "validations": {
            "required": true,
            "min": 5,
            "max": 200
          },
          "i18n": {
            "labelKey": "ecr.checkout.shipping.address.label",
            "placeholderKey": "ecr.checkout.shipping.address.placeholder"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.checkout.shipping.address.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 1
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 12 }
            }
          }
        },
        {
          "id": "shippingCityInput",
          "type": "input",
          "adapterHint": "platform.textField",
          "props": {
            "label": "City",
            "placeholder": "Enter your city"
          },
          "bindings": {
            "data": {
              "value": "data.checkout.shipping.city"
            }
          },
          "validations": {
            "required": true,
            "min": 2,
            "max": 100
          },
          "i18n": {
            "labelKey": "ecr.checkout.shipping.city.label",
            "placeholderKey": "ecr.checkout.shipping.city.placeholder"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.checkout.shipping.city.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 2
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 6 }
            }
          }
        },
        {
          "id": "shippingPostalCodeInput",
          "type": "input",
          "adapterHint": "platform.textField",
          "props": {
            "label": "Postal Code",
            "placeholder": "Enter postal code"
          },
          "bindings": {
            "data": {
              "value": "data.checkout.shipping.postalCode"
            }
          },
          "validations": {
            "required": true,
            "min": 3,
            "max": 20,
            "regex": "^[A-Za-z0-9\\s-]+$"
          },
          "i18n": {
            "labelKey": "ecr.checkout.shipping.postalCode.label",
            "placeholderKey": "ecr.checkout.shipping.postalCode.placeholder"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.checkout.shipping.postalCode.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 3
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 6 }
            }
          }
        },
        {
          "id": "paymentMethodSelect",
          "type": "select",
          "adapterHint": "platform.select",
          "props": {
            "label": "Payment Method",
            "placeholder": "Select payment method",
            "options": [
              { "value": "credit_card", "label": "Credit Card" },
              { "value": "debit_card", "label": "Debit Card" },
              { "value": "paypal", "label": "PayPal" },
              { "value": "bank_transfer", "label": "Bank Transfer" }
            ]
          },
          "bindings": {
            "data": {
              "value": "data.checkout.paymentMethod"
            }
          },
          "validations": {
            "required": true
          },
          "i18n": {
            "labelKey": "ecr.checkout.payment.method.label",
            "placeholderKey": "ecr.checkout.payment.method.placeholder"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.checkout.payment.method.aria",
            "tabIndex": 0,
            "role": "combobox",
            "keyboardNav": true,
            "focusOrder": 4
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 6 }
            }
          }
        },
        {
          "id": "placeOrderButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Place Order",
            "variant": "solid",
            "intent": "primary",
            "size": "lg"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onPlaceOrder" } }
            ]
          },
          "i18n": {
            "labelKey": "ecr.checkout.placeOrder"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.checkout.placeOrder.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 5
          }
        }
      ]
    },
    "confirmation": {
      "version": "1.0.0",
      "pageId": "confirmation",
      "layout": {
        "id": "confirmation-root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "confirmation-header-section",
            "type": "section",
            "title": "Order Confirmed",
            "componentIds": ["orderConfirmationAlert"]
          },
          {
            "id": "confirmation-details-section",
            "type": "section",
            "title": "Order Details",
            "componentIds": ["orderSummaryTable"]
          },
          {
            "id": "confirmation-actions-section",
            "type": "section",
            "title": "Next Steps",
            "componentIds": ["continueShoppingButton"]
          }
        ]
      },
      "components": [
        {
          "id": "orderConfirmationAlert",
          "type": "text",
          "adapterHint": "platform.alert",
          "props": {
            "title": "Order Placed Successfully!",
            "description": "Your order has been confirmed. Check your email for order details and tracking information.",
            "intent": "success"
          },
          "bindings": {
            "data": {
              "value": "data.order.reference"
            }
          },
          "i18n": {
            "labelKey": "ecr.confirmation.reference"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.confirmation.reference.aria",
            "tabIndex": 0,
            "role": "status",
            "keyboardNav": true,
            "focusOrder": 1
          }
        },
        {
          "id": "orderSummaryTable",
          "type": "table",
          "adapterHint": "aggrid.table",
          "props": {
            "columns": [
              { "field": "item", "headerKey": "ecr.confirmation.item" },
              { "field": "quantity", "headerKey": "ecr.confirmation.quantity" },
              { "field": "price", "headerKey": "ecr.confirmation.price" },
              { "field": "subtotal", "headerKey": "ecr.confirmation.subtotal" }
            ],
            "rows": []
          },
          "bindings": {
            "data": {
              "rows": "data.order.summary"
            }
          },
          "i18n": {
            "labelKey": "ecr.confirmation.summary.table"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.confirmation.summary.table.aria",
            "tabIndex": 0,
            "role": "table",
            "keyboardNav": true,
            "focusOrder": 2
          }
        },
        {
          "id": "continueShoppingButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Continue Shopping",
            "variant": "outline",
            "intent": "primary",
            "size": "md"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onContinueShopping" } }
            ]
          },
          "i18n": {
            "labelKey": "ecr.confirmation.continueShopping"
          },
          "accessibility": {
            "ariaLabelKey": "ecr.confirmation.continueShopping.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 3
          }
        }
      ]
    }
  },
  "activeUiPageId": "home",
  "flowSchema": {
    "version": "1.0.0",
    "flowId": "ecr-commerce-flow",
    "initialState": "home",
    "states": {
      "home": {
        "uiPageId": "home",
        "on": {
          "onSelectProduct": {
            "target": "product"
          }
        }
      },
      "product": {
        "uiPageId": "product",
        "on": {
          "onAddToCart": {
            "target": "cart",
            "actions": ["evaluateRules"]
          }
        }
      },
      "cart": {
        "uiPageId": "cart",
        "on": {
          "onCheckout": {
            "target": "checkout",
            "guard": {
              "op": "gt",
              "left": { "path": "data.cart.items.length" },
              "right": { "value": 0 }
            }
          }
        }
      },
      "checkout": {
        "uiPageId": "checkout",
        "on": {
          "onPlaceOrder": {
            "target": "confirmation",
            "guard": {
              "all": [
                {
                  "op": "exists",
                  "left": { "path": "data.checkout.shipping.address" }
                },
                {
                  "op": "exists",
                  "left": { "path": "data.checkout.shipping.city" }
                },
                {
                  "op": "exists",
                  "left": { "path": "data.checkout.shipping.postalCode" }
                }
              ]
            },
            "actions": ["evaluateRules", "callApi"],
            "apiId": "submitOrder"
          }
        }
      },
      "confirmation": {
        "uiPageId": "confirmation",
        "on": {
          "onContinueShopping": {
            "target": "home"
          }
        }
      }
    }
  },
  "rules": {
    "version": "1.0.0",
    "rules": [
      {
        "ruleId": "CartNotEmpty",
        "description": "Ensure at least one item exists in the cart before allowing checkout",
        "priority": 100,
        "when": {
          "op": "gt",
          "left": { "path": "data.cart.items.length" },
          "right": { "value": 0 }
        }
      },
      {
        "ruleId": "ApplyDiscount",
        "description": "Apply a 10% discount when cart total exceeds $100",
        "priority": 90,
        "when": {
          "op": "gt",
          "left": { "path": "data.cart.total" },
          "right": { "value": 100 }
        },
        "actions": [
          {
            "type": "setField",
            "path": "data.cart.discountPercent",
            "value": 10
          },
          {
            "type": "setField",
            "path": "data.cart.discountApplied",
            "value": true
          },
          {
            "type": "emitEvent",
            "event": "discountApplied",
            "payload": { "percent": 10 }
          }
        ]
      },
      {
        "ruleId": "RequiredFieldsPresent",
        "description": "Validate that all required shipping fields are present before order placement",
        "priority": 80,
        "when": {
          "all": [
            {
              "op": "exists",
              "left": { "path": "data.checkout.shipping.address" }
            },
            {
              "op": "exists",
              "left": { "path": "data.checkout.shipping.city" }
            },
            {
              "op": "exists",
              "left": { "path": "data.checkout.shipping.postalCode" }
            }
          ]
        }
      },
      {
        "ruleId": "UserIsAdmin",
        "description": "Check if the current user has admin role for admin panel access",
        "priority": 70,
        "when": {
          "op": "eq",
          "left": { "path": "data.user.role" },
          "right": { "value": "admin" }
        }
      }
    ]
  },
  "apiMappingsById": {
    "submitOrder": {
      "version": "1.0.0",
      "apiId": "submitOrder",
      "type": "rest",
      "method": "POST",
      "endpoint": "https://api.ecr-commerce.example.com/orders",
      "requestMap": {
        "body": {
          "cartItems": { "from": "data.cart.items" },
          "cartTotal": { "from": "data.cart.total" },
          "discountApplied": { "from": "data.cart.discountApplied" },
          "discountPercent": { "from": "data.cart.discountPercent" },
          "shippingAddress": { "from": "data.checkout.shipping.address" },
          "shippingCity": { "from": "data.checkout.shipping.city" },
          "shippingPostalCode": { "from": "data.checkout.shipping.postalCode" },
          "paymentMethod": { "from": "data.checkout.paymentMethod" },
          "customerId": { "from": "context.userId" },
          "locale": { "from": "context.locale" }
        },
        "headers": {
          "authorization": { "from": "context.permissions[0]" },
          "x-tenant": { "from": "context.tenantId" }
        }
      },
      "responseMap": {
        "data": {
          "order.reference": "response.orderReference",
          "order.status": "response.status",
          "order.summary": "response.summary"
        },
        "context": {
          "lastOrderId": "response.orderId"
        }
      },
      "transforms": [],
      "errorHandling": {
        "map": {
          "400": "INVALID_ORDER",
          "401": "UNAUTHORIZED",
          "422": "VALIDATION_FAILED",
          "500": "SERVER_ERROR"
        },
        "retry": {
          "maxAttempts": 2,
          "backoffMs": 500
        }
      }
    }
  }
}
