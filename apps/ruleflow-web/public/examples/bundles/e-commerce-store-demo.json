{
  "uiSchema": {
    "version": "1.0.0",
    "pageId": "dashboard",
    "layout": {
      "id": "root",
      "type": "stack",
      "direction": "vertical",
      "children": [
        {
          "id": "filters",
          "type": "section",
          "title": "Filters",
          "componentIds": ["customerNameInput", "orderTotalInput"]
        },
        {
          "id": "table",
          "type": "section",
          "title": "Orders",
          "componentIds": ["ordersTable"]
        },
        {
          "id": "chart",
          "type": "section",
          "title": "Revenue",
          "componentIds": ["revenueChart"]
        },
        {
          "id": "viz",
          "type": "section",
          "title": "Custom Insight",
          "componentIds": ["customViz"]
        }
      ]
    },
    "components": [
      {
        "id": "customerNameInput",
        "type": "input",
        "adapterHint": "material.input",
        "props": {},
        "i18n": {
          "labelKey": "runtime.filters.customerName.label",
          "placeholderKey": "runtime.filters.customerName.placeholder",
          "helperTextKey": "runtime.filters.customerName.helper"
        },
        "bindings": {
          "data": {
            "value": "data.filters.customerName"
          }
        },
        "validations": {
          "required": false,
          "min": 2,
          "max": 64,
          "regex": "^[a-zA-Z\\s]+$"
        },
        "accessibility": {
          "ariaLabelKey": "runtime.filters.customerName.aria",
          "tabIndex": 0,
          "role": "textbox",
          "keyboardNav": true,
          "focusOrder": 1
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 6 }
          }
        },
        "events": {
          "onChange": [
            { "type": "emitEvent", "payload": { "event": "filterChanged" } }
          ]
        }
      },
      {
        "id": "orderTotalInput",
        "type": "input",
        "adapterHint": "material.input",
        "props": {
          "inputType": "number"
        },
        "i18n": {
          "labelKey": "runtime.filters.orderTotal.label",
          "placeholderKey": "runtime.filters.orderTotal.placeholder",
          "helperTextKey": "runtime.filters.orderTotal.helper"
        },
        "bindings": {
          "data": {
            "value": "data.orderTotal"
          }
        },
        "accessibility": {
          "ariaLabelKey": "runtime.filters.orderTotal.aria",
          "tabIndex": 0,
          "role": "spinbutton",
          "keyboardNav": true,
          "focusOrder": 2
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 6 }
          }
        }
      },
      {
        "id": "ordersTable",
        "type": "table",
        "adapterHint": "aggrid.table",
        "props": {
          "columns": [
            { "field": "orderId", "headerKey": "runtime.orders.table.columns.orderId" },
            { "field": "customer", "headerKey": "runtime.orders.table.columns.customer" },
            { "field": "total", "headerKey": "runtime.orders.table.columns.total" }
          ],
          "rows": []
        },
        "i18n": {
          "labelKey": "runtime.orders.table.label"
        },
        "bindings": {
          "data": {
            "rows": "data.orders"
          }
        },
        "accessibility": {
          "ariaLabelKey": "runtime.orders.table.aria",
          "tabIndex": 0,
          "role": "table",
          "keyboardNav": true,
          "focusOrder": 3
        }
      },
      {
        "id": "revenueChart",
        "type": "chart",
        "adapterHint": "highcharts.chart",
        "props": {
          "series": []
        },
        "i18n": {
          "labelKey": "runtime.revenue.chart.label"
        },
        "bindings": {
          "data": {
            "series": "data.revenueSeries"
          }
        },
        "accessibility": {
          "ariaLabelKey": "runtime.revenue.chart.aria",
          "tabIndex": 0,
          "role": "img",
          "keyboardNav": true,
          "focusOrder": 4
        }
      },
      {
        "id": "customViz",
        "type": "custom",
        "adapterHint": "d3.custom",
        "props": {
          "height": 240
        },
        "i18n": {
          "labelKey": "runtime.customViz.label"
        },
        "bindings": {
          "data": {
            "dataset": "data.customViz"
          }
        },
        "accessibility": {
          "ariaLabelKey": "runtime.customViz.aria",
          "tabIndex": 0,
          "role": "img",
          "keyboardNav": true,
          "focusOrder": 5
        }
      }
    ]
  },
