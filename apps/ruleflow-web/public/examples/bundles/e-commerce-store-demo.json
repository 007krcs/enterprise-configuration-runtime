{
  "uiSchema": {
    "version": "1.0.0",
    "pageId": "home",
    "layout": {
      "id": "home-root",
      "type": "stack",
      "direction": "vertical",
      "children": [
        {
          "id": "home-hero",
          "type": "section",
          "title": "Welcome",
          "componentIds": ["heroText"]
        },
        {
          "id": "home-categories",
          "type": "section",
          "title": "Shop by Category",
          "componentIds": ["categoryCard1", "categoryCard2", "categoryCard3"]
        },
        {
          "id": "home-featured",
          "type": "section",
          "title": "Featured Products",
          "componentIds": ["featuredProductsTable"]
        }
      ]
    },
    "components": [
      {
        "id": "heroText",
        "type": "text",
        "adapterHint": "platform.alert",
        "props": {
          "title": "Welcome to ECR Commerce",
          "description": "Discover our curated collection of products across electronics, clothing, and home & garden",
          "intent": "primary"
        },
        "i18n": {
          "labelKey": "ecr.home.hero.title"
        },
        "accessibility": {
          "ariaLabelKey": "ecr.home.hero.aria",
          "tabIndex": 0,
          "role": "heading",
          "keyboardNav": true,
          "focusOrder": 1
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 12 }
          }
        }
      },
      {
        "id": "categoryCard1",
        "type": "card",
        "adapterHint": "platform.alert",
        "props": {
          "title": "Electronics",
          "description": "Laptops, phones & accessories",
          "intent": "neutral"
        },
        "bindings": {
          "data": {
            "value": "data.categories[0]"
          }
        },
        "events": {
          "onClick": [
            { "type": "emitEvent", "payload": { "event": "onSelectProduct" } }
          ]
        },
        "accessibility": {
          "ariaLabelKey": "ecr.home.category.electronics.aria",
          "tabIndex": 0,
          "role": "button",
          "keyboardNav": true,
          "focusOrder": 2
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 4 }
          }
        }
      },
      {
        "id": "categoryCard2",
        "type": "card",
        "adapterHint": "platform.alert",
        "props": {
          "title": "Clothing",
          "description": "Apparel & fashion",
          "intent": "neutral"
        },
        "bindings": {
          "data": {
            "value": "data.categories[1]"
          }
        },
        "events": {
          "onClick": [
            { "type": "emitEvent", "payload": { "event": "onSelectProduct" } }
          ]
        },
        "accessibility": {
          "ariaLabelKey": "ecr.home.category.clothing.aria",
          "tabIndex": 0,
          "role": "button",
          "keyboardNav": true,
          "focusOrder": 3
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 4 }
          }
        }
      },
      {
        "id": "categoryCard3",
        "type": "card",
        "adapterHint": "platform.alert",
        "props": {
          "title": "Home & Garden",
          "description": "Furniture & decor",
          "intent": "neutral"
        },
        "bindings": {
          "data": {
            "value": "data.categories[2]"
          }
        },
        "events": {
          "onClick": [
            { "type": "emitEvent", "payload": { "event": "onSelectProduct" } }
          ]
        },
        "accessibility": {
          "ariaLabelKey": "ecr.home.category.home.aria",
          "tabIndex": 0,
          "role": "button",
          "keyboardNav": true,
          "focusOrder": 4
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 4 }
          }
        }
      },
      {
        "id": "featuredProductsTable",
        "type": "table",
        "adapterHint": "aggrid.table",
        "props": {
          "columns": [
            { "field": "name", "headerKey": "ecr.products.name" },
            { "field": "price", "headerKey": "ecr.products.price" },
            { "field": "category", "headerKey": "ecr.products.category" },
            { "field": "rating", "headerKey": "ecr.products.rating" }
          ],
          "rows": []
        },
        "bindings": {
          "data": {
            "rows": "data.products"
          }
        },
        "i18n": {
          "labelKey": "ecr.home.featured.table"
        },
        "accessibility": {
          "ariaLabelKey": "ecr.home.featured.table.aria",
          "tabIndex": 0,
          "role": "table",
          "keyboardNav": true,
          "focusOrder": 5
        }
      }
    ]
  },
