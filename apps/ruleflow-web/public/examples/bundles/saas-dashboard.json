{
  "uiSchema": {
    "version": "1.0.0",
    "pageId": "login",
    "layout": {
      "id": "root",
      "type": "stack",
      "direction": "vertical",
      "children": [
        {
          "id": "login-header",
          "type": "section",
          "title": "SaaS Insights Platform",
          "componentIds": ["appTitle"]
        },
        {
          "id": "login-form",
          "type": "section",
          "title": "Sign In",
          "componentIds": ["loginUsername", "loginPassword", "loginButton"]
        }
      ]
    },
    "components": [
      {
        "id": "appTitle",
        "type": "text",
        "adapterHint": "platform.alert",
        "props": {
          "title": "SaaS Insights Platform",
          "description": "Sign in to access your analytics dashboard",
          "intent": "primary"
        },
        "accessibility": {
          "ariaLabelKey": "examples.saas.appTitle.aria",
          "tabIndex": 0,
          "role": "heading",
          "keyboardNav": true,
          "focusOrder": 1
        }
      },
      {
        "id": "loginUsername",
        "type": "input",
        "adapterHint": "platform.textField",
        "props": {
          "label": "Username",
          "placeholder": "Enter your username"
        },
        "bindings": {
          "data": {
            "value": "data.user.username"
          }
        },
        "validations": {
          "required": true
        },
        "i18n": {
          "labelKey": "examples.saas.login.username",
          "placeholderKey": "examples.saas.login.username.placeholder"
        },
        "accessibility": {
          "ariaLabelKey": "examples.saas.login.username.aria",
          "tabIndex": 0,
          "role": "textbox",
          "keyboardNav": true,
          "focusOrder": 2
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 6 }
          }
        }
      },
      {
        "id": "loginPassword",
        "type": "input",
        "adapterHint": "platform.textField",
        "props": {
          "label": "Password",
          "placeholder": "Enter your password"
        },
        "bindings": {
          "data": {
            "value": "data.user.password"
          }
        },
        "validations": {
          "required": true
        },
        "i18n": {
          "labelKey": "examples.saas.login.password",
          "placeholderKey": "examples.saas.login.password.placeholder"
        },
        "accessibility": {
          "ariaLabelKey": "examples.saas.login.password.aria",
          "tabIndex": 0,
          "role": "textbox",
          "keyboardNav": true,
          "focusOrder": 3
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 6 }
          }
        }
      },
      {
        "id": "loginButton",
        "type": "button",
        "adapterHint": "platform.button",
        "props": {
          "label": "Sign In",
          "variant": "solid",
          "intent": "primary",
          "size": "lg"
        },
        "events": {
          "onClick": [
            { "type": "emitEvent", "payload": { "event": "onLogin" } }
          ]
        },
        "accessibility": {
          "ariaLabelKey": "examples.saas.login.submit.aria",
          "tabIndex": 0,
          "role": "button",
          "keyboardNav": true,
          "focusOrder": 4
        }
      }
    ]
  },
