  "activeUiPageId": "login",
  "flowSchema": {
    "version": "1.0.0",
    "flowId": "saas-dashboard-flow",
    "initialState": "login",
    "states": {
      "login": {
        "uiPageId": "login",
        "on": {
          "onLogin": {
            "target": "dashboard",
            "guard": {
              "op": "exists",
              "left": {
                "path": "data.user.token"
              }
            }
          }
        }
      },
      "dashboard": {
        "uiPageId": "dashboard",
        "on": {
          "onViewReports": {
            "target": "reports",
            "guard": {
              "op": "eq",
              "left": {
                "path": "context.role"
              },
              "right": {
                "value": "admin"
              }
            }
          },
          "onInactivityTimeout": {
            "target": "login",
            "guard": {
              "op": "eq",
              "left": {
                "path": "data.hostEvent"
              },
              "right": {
                "value": "onInactivityTimeout"
              }
            }
          }
        }
      },
      "reports": {
        "uiPageId": "reports",
        "on": {
          "onBackToDashboard": {
            "target": "dashboard"
          },
          "onExportReport": {
            "target": "reports",
            "actions": ["callApi"],
            "apiId": "exportReport"
          },
          "onInactivityTimeout": {
            "target": "login",
            "guard": {
              "op": "eq",
              "left": {
                "path": "data.hostEvent"
              },
              "right": {
                "value": "onInactivityTimeout"
              }
            }
          }
        }
      }
    }
  },
  "rules": {
    "version": "1.0.0",
    "rules": [
      {
        "ruleId": "IsAuthenticated",
        "description": "Checks that the user has a valid authentication token before allowing login transition",
        "priority": 100,
        "when": {
          "op": "exists",
          "left": {
            "path": "data.user.token"
          }
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.authenticated",
            "value": true
          }
        ]
      },
      {
        "ruleId": "IsAdmin",
        "description": "Checks that the current user has admin role, granting access to reports",
        "priority": 90,
        "when": {
          "op": "eq",
          "left": {
            "path": "context.role"
          },
          "right": {
            "value": "admin"
          }
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.adminAccess",
            "value": true
          }
        ]
      },
      {
        "ruleId": "InactivityLogout",
        "description": "Simulated timeout rule that forces redirect to login when host reports inactivity",
        "priority": 80,
        "when": {
          "op": "eq",
          "left": {
            "path": "data.hostEvent"
          },
          "right": {
            "value": "onInactivityTimeout"
          }
        },
        "actions": [
          {
            "type": "emitEvent",
            "event": "onInactivityTimeout"
          },
          {
            "type": "setField",
            "path": "data.user.token",
            "value": null
          },
          {
            "type": "setContext",
            "path": "context.authenticated",
            "value": false
          }
        ]
      },
      {
        "ruleId": "RoleBasedAccess",
        "description": "Restricts access to reports screen to users with admin role only",
        "priority": 70,
        "scope": {
          "roles": ["user", "viewer"]
        },
        "when": {
          "op": "neq",
          "left": {
            "path": "context.role"
          },
          "right": {
            "value": "admin"
          }
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.adminAccess",
            "value": false
          },
          {
            "type": "throwError",
            "message": "Access denied: admin role required to view reports",
            "code": "ROLE_ACCESS_DENIED"
          }
        ]
      }
    ]
  },
  "apiMappingsById": {
    "fetchMetrics": {
      "version": "1.0.0",
      "apiId": "fetchMetrics",
      "type": "rest",
      "method": "GET",
      "endpoint": "https://api.example.com/metrics",
      "requestMap": {
        "headers": {
          "Authorization": { "from": "data.user.token", "transform": "concat('Bearer ', $)" },
          "x-tenant": { "from": "context.tenantId" }
        },
        "query": {
          "period": { "from": "context.metricsPeriod" }
        }
      },
      "responseMap": {
        "data": {
          "metrics.revenue": "response.revenue",
          "metrics.activeUsers": "response.activeUsers",
          "metrics.csat": "response.csat",
          "metrics.revenueSeries": "response.revenueSeries",
          "metrics.byRegion": "response.byRegion"
        }
      },
      "transforms": [
        { "name": "concat", "expression": "concat($1, $2)" }
      ],
      "errorHandling": {
        "map": {
          "401": "UNAUTHORIZED",
          "403": "FORBIDDEN",
          "500": "SERVER_ERROR"
        },
        "retry": {
          "maxAttempts": 3,
          "backoffMs": 500
        }
      }
    },
    "exportReport": {
      "version": "1.0.0",
      "apiId": "exportReport",
      "type": "rest",
      "method": "POST",
      "endpoint": "https://api.example.com/reports/export",
      "requestMap": {
        "body": {
          "reportIds": { "from": "data.selectedReportIds" },
          "format": { "from": "context.exportFormat" },
          "requestedBy": { "from": "data.user.username" }
        },
        "headers": {
          "Authorization": { "from": "data.user.token", "transform": "concat('Bearer ', $)" },
          "x-tenant": { "from": "context.tenantId" }
        }
      },
      "responseMap": {
        "data": {
          "exportUrl": "response.downloadUrl",
          "exportStatus": "response.status"
        },
        "context": {
          "lastExportRequestId": "response.requestId"
        }
      },
      "transforms": [
        { "name": "concat", "expression": "concat($1, $2)" }
      ],
      "errorHandling": {
        "map": {
          "400": "BAD_REQUEST",
          "401": "UNAUTHORIZED",
          "500": "SERVER_ERROR"
        },
        "retry": {
          "maxAttempts": 2,
          "backoffMs": 1000
        }
      }
    }
  }
}
