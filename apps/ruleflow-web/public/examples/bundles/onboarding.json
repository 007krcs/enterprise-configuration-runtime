{
  "uiSchema": {
    "version": "1.0.0",
    "pageId": "welcome",
    "layout": {
      "id": "root",
      "type": "stack",
      "direction": "vertical",
      "children": [
        {
          "id": "welcome-header",
          "type": "section",
          "title": "Welcome",
          "componentIds": ["welcomeTitle", "welcomeSubtitle"]
        },
        {
          "id": "welcome-features",
          "type": "section",
          "title": "Platform Highlights",
          "componentIds": ["featureCard1", "featureCard2", "featureCard3"]
        },
        {
          "id": "welcome-actions",
          "type": "section",
          "title": "Actions",
          "componentIds": ["getStartedButton"]
        }
      ]
    },
    "components": [
      {
        "id": "welcomeTitle",
        "type": "text",
        "adapterHint": "platform.alert",
        "props": {
          "title": "Welcome to ECR Platform",
          "intent": "primary"
        },
        "i18n": {
          "labelKey": "onboarding.welcome.title"
        },
        "accessibility": {
          "ariaLabelKey": "onboarding.welcome.title.aria",
          "tabIndex": 0,
          "role": "heading",
          "keyboardNav": true,
          "focusOrder": 1
        }
      },
      {
        "id": "welcomeSubtitle",
        "type": "text",
        "adapterHint": "platform.alert",
        "props": {
          "title": "Getting Started",
          "description": "Let's set up your workspace in a few simple steps",
          "intent": "neutral"
        },
        "i18n": {
          "labelKey": "onboarding.welcome.subtitle"
        },
        "accessibility": {
          "ariaLabelKey": "onboarding.welcome.subtitle.aria",
          "tabIndex": 0,
          "role": "status",
          "keyboardNav": true,
          "focusOrder": 2
        }
      },
      {
        "id": "featureCard1",
        "type": "text",
        "adapterHint": "platform.alert",
        "props": {
          "title": "Rule Engine",
          "description": "Build and deploy business rules with a visual editor",
          "intent": "success"
        },
        "accessibility": {
          "ariaLabelKey": "onboarding.feature.ruleEngine.aria",
          "tabIndex": 0,
          "role": "region",
          "keyboardNav": true,
          "focusOrder": 3
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 4 }
          }
        }
      },
      {
        "id": "featureCard2",
        "type": "text",
        "adapterHint": "platform.alert",
        "props": {
          "title": "Flow Designer",
          "description": "Create multi-step workflows with drag-and-drop simplicity",
          "intent": "primary"
        },
        "accessibility": {
          "ariaLabelKey": "onboarding.feature.flowDesigner.aria",
          "tabIndex": 0,
          "role": "region",
          "keyboardNav": true,
          "focusOrder": 4
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 4 }
          }
        }
      },
      {
        "id": "featureCard3",
        "type": "text",
        "adapterHint": "platform.alert",
        "props": {
          "title": "Analytics Dashboard",
          "description": "Monitor performance with real-time insights",
          "intent": "neutral"
        },
        "accessibility": {
          "ariaLabelKey": "onboarding.feature.analytics.aria",
          "tabIndex": 0,
          "role": "region",
          "keyboardNav": true,
          "focusOrder": 5
        },
        "responsive": {
          "breakpoints": {
            "sm": { "columns": 12, "span": 12 },
            "md": { "columns": 12, "span": 4 }
          }
        }
      },
      {
        "id": "getStartedButton",
        "type": "button",
        "adapterHint": "platform.button",
        "props": {
          "label": "Get Started",
          "variant": "solid",
          "intent": "primary",
          "size": "lg"
        },
        "events": {
          "onClick": [
            { "type": "emitEvent", "payload": { "event": "onGetStarted" } }
          ]
        },
        "accessibility": {
          "ariaLabelKey": "onboarding.getStarted.aria",
          "tabIndex": 0,
          "role": "button",
          "keyboardNav": true,
          "focusOrder": 6
        }
      }
    ]
  },
