{
  "uiSchema": {
    "version": "1.0.0",
    "pageId": "welcome",
    "layout": {
      "id": "root",
      "type": "stack",
      "direction": "vertical",
      "children": [
        {
          "id": "welcome-header",
          "type": "section",
          "title": "Welcome",
          "componentIds": ["welcomeTitle", "welcomeSubtitle"]
        },
        {
          "id": "welcome-features",
          "type": "section",
          "title": "Platform Highlights",
          "componentIds": ["featureCard1", "featureCard2", "featureCard3"]
        },
        {
          "id": "welcome-actions",
          "type": "section",
          "title": "Actions",
          "componentIds": ["getStartedButton"]
        }
      ]
    },
    "components": [
      {
        "id": "welcomeTitle",
        "type": "text",
        "adapterHint": "material.text",
        "props": {
          "text": "Welcome to ECR Platform",
          "variant": "h4",
          "alignment": "center"
        }
      },
      {
        "id": "welcomeSubtitle",
        "type": "text",
        "adapterHint": "material.text",
        "props": {
          "text": "Let's set up your workspace in a few simple steps",
          "variant": "subtitle1",
          "alignment": "center"
        }
      },
      {
        "id": "featureCard1",
        "type": "text",
        "adapterHint": "material.text",
        "props": {
          "text": "Rule Engine - Build and deploy business rules with a visual editor",
          "variant": "body1"
        }
      },
      {
        "id": "featureCard2",
        "type": "text",
        "adapterHint": "material.text",
        "props": {
          "text": "Flow Designer - Create multi-step workflows with drag-and-drop simplicity",
          "variant": "body1"
        }
      },
      {
        "id": "featureCard3",
        "type": "text",
        "adapterHint": "material.text",
        "props": {
          "text": "Analytics Dashboard - Monitor performance with real-time insights",
          "variant": "body1"
        }
      },
      {
        "id": "getStartedButton",
        "type": "button",
        "adapterHint": "material.button",
        "props": {
          "label": "Get Started",
          "variant": "contained",
          "color": "primary"
        },
        "events": {
          "onClick": [
            { "type": "emitEvent", "event": "onGetStarted" }
          ]
        }
      }
    ]
  },
  "uiSchemasById": {
    "welcome": {
      "version": "1.0.0",
      "pageId": "welcome",
      "layout": {
        "id": "root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "welcome-header",
            "type": "section",
            "title": "Welcome",
            "componentIds": ["welcomeTitle", "welcomeSubtitle"]
          },
          {
            "id": "welcome-features",
            "type": "section",
            "title": "Platform Highlights",
            "componentIds": ["featureCard1", "featureCard2", "featureCard3"]
          },
          {
            "id": "welcome-actions",
            "type": "section",
            "title": "Actions",
            "componentIds": ["getStartedButton"]
          }
        ]
      },
      "components": [
        {
          "id": "welcomeTitle",
          "type": "text",
          "adapterHint": "material.text",
          "props": {
            "text": "Welcome to ECR Platform",
            "variant": "h4",
            "alignment": "center"
          }
        },
        {
          "id": "welcomeSubtitle",
          "type": "text",
          "adapterHint": "material.text",
          "props": {
            "text": "Let's set up your workspace in a few simple steps",
            "variant": "subtitle1",
            "alignment": "center"
          }
        },
        {
          "id": "featureCard1",
          "type": "text",
          "adapterHint": "material.text",
          "props": {
            "text": "Rule Engine - Build and deploy business rules with a visual editor",
            "variant": "body1"
          }
        },
        {
          "id": "featureCard2",
          "type": "text",
          "adapterHint": "material.text",
          "props": {
            "text": "Flow Designer - Create multi-step workflows with drag-and-drop simplicity",
            "variant": "body1"
          }
        },
        {
          "id": "featureCard3",
          "type": "text",
          "adapterHint": "material.text",
          "props": {
            "text": "Analytics Dashboard - Monitor performance with real-time insights",
            "variant": "body1"
          }
        },
        {
          "id": "getStartedButton",
          "type": "button",
          "adapterHint": "material.button",
          "props": {
            "label": "Get Started",
            "variant": "contained",
            "color": "primary"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "event": "onGetStarted" }
            ]
          }
        }
      ]
    },
    "account-setup": {
      "version": "1.0.0",
      "pageId": "account-setup",
      "layout": {
        "id": "root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "account-header",
            "type": "section",
            "title": "Account Details",
            "componentIds": ["accountSectionTitle"]
          },
          {
            "id": "account-form",
            "type": "section",
            "title": "Your Information",
            "componentIds": ["accountFullName", "accountEmail", "accountOrg"]
          },
          {
            "id": "account-actions",
            "type": "section",
            "title": "Actions",
            "componentIds": ["accountBackButton", "accountNextButton"]
          }
        ]
      },
      "components": [
        {
          "id": "accountSectionTitle",
          "type": "text",
          "adapterHint": "material.text",
          "props": {
            "text": "Account Details",
            "variant": "h5",
            "alignment": "left"
          }
        },
        {
          "id": "accountFullName",
          "type": "input",
          "adapterHint": "material.input",
          "props": {
            "label": "Full Name",
            "placeholder": "Enter your full name",
            "inputType": "text"
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.accountName"
            }
          },
          "validations": {
            "required": true,
            "min": 2,
            "max": 100
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.accountName.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 1
          }
        },
        {
          "id": "accountEmail",
          "type": "input",
          "adapterHint": "material.input",
          "props": {
            "label": "Email Address",
            "placeholder": "you@example.com",
            "inputType": "email"
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.accountEmail"
            }
          },
          "validations": {
            "required": true,
            "regex": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.accountEmail.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 2
          }
        },
        {
          "id": "accountOrg",
          "type": "input",
          "adapterHint": "material.input",
          "props": {
            "label": "Organization Name",
            "placeholder": "Your company or team name",
            "inputType": "text"
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.accountOrg"
            }
          },
          "validations": {
            "required": false
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.accountOrg.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 3
          }
        },
        {
          "id": "accountBackButton",
          "type": "button",
          "adapterHint": "material.button",
          "props": {
            "label": "Back",
            "variant": "outlined",
            "color": "secondary"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "event": "onBack" }
            ]
          }
        },
        {
          "id": "accountNextButton",
          "type": "button",
          "adapterHint": "material.button",
          "props": {
            "label": "Next",
            "variant": "contained",
            "color": "primary"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "event": "onNext" }
            ]
          },
          "disabledWhen": {
            "op": "eq",
            "left": { "path": "context.onboarding.nextEnabled" },
            "right": { "value": false }
          }
        }
      ]
    },
    "preferences": {
      "version": "1.0.0",
      "pageId": "preferences",
      "layout": {
        "id": "root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "preferences-header",
            "type": "section",
            "title": "Configure Preferences",
            "componentIds": ["preferencesSectionTitle"]
          },
          {
            "id": "preferences-form",
            "type": "section",
            "title": "Settings",
            "componentIds": ["preferenceTier", "preferenceRegion", "preferenceNotifications"]
          },
          {
            "id": "preferences-actions",
            "type": "section",
            "title": "Actions",
            "componentIds": ["preferencesBackButton", "preferencesNextButton"]
          }
        ]
      },
      "components": [
        {
          "id": "preferencesSectionTitle",
          "type": "text",
          "adapterHint": "material.text",
          "props": {
            "text": "Configure Preferences",
            "variant": "h5",
            "alignment": "left"
          }
        },
        {
          "id": "preferenceTier",
          "type": "select",
          "adapterHint": "material.select",
          "props": {
            "label": "Subscription Tier",
            "options": [
              { "label": "Free", "value": "free" },
              { "label": "Pro", "value": "pro" },
              { "label": "Enterprise", "value": "enterprise" }
            ]
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.preferenceTier"
            }
          },
          "validations": {
            "required": true
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.preferenceTier.aria",
            "tabIndex": 0,
            "role": "listbox",
            "keyboardNav": true,
            "focusOrder": 1
          }
        },
        {
          "id": "preferenceRegion",
          "type": "select",
          "adapterHint": "material.select",
          "props": {
            "label": "Region",
            "options": [
              { "label": "Americas", "value": "americas" },
              { "label": "EMEA", "value": "emea" },
              { "label": "APAC", "value": "apac" }
            ]
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.preferenceRegion"
            }
          },
          "validations": {
            "required": false
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.preferenceRegion.aria",
            "tabIndex": 0,
            "role": "listbox",
            "keyboardNav": true,
            "focusOrder": 2
          }
        },
        {
          "id": "preferenceNotifications",
          "type": "select",
          "adapterHint": "material.select",
          "props": {
            "label": "Notifications",
            "options": [
              { "label": "Enabled", "value": "enabled" },
              { "label": "Disabled", "value": "disabled" }
            ]
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.preferenceNotifications"
            }
          },
          "validations": {
            "required": false
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.preferenceNotifications.aria",
            "tabIndex": 0,
            "role": "listbox",
            "keyboardNav": true,
            "focusOrder": 3
          }
        },
        {
          "id": "preferencesBackButton",
          "type": "button",
          "adapterHint": "material.button",
          "props": {
            "label": "Back",
            "variant": "outlined",
            "color": "secondary"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "event": "onBack" }
            ]
          }
        },
        {
          "id": "preferencesNextButton",
          "type": "button",
          "adapterHint": "material.button",
          "props": {
            "label": "Next",
            "variant": "contained",
            "color": "primary"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "event": "onNext" }
            ]
          },
          "disabledWhen": {
            "op": "eq",
            "left": { "path": "context.onboarding.preferencesValid" },
            "right": { "value": false }
          }
        }
      ]
    },
    "finish": {
      "version": "1.0.0",
      "pageId": "finish",
      "layout": {
        "id": "root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "finish-header",
            "type": "section",
            "title": "Complete",
            "componentIds": ["finishTitle", "finishSummary"]
          },
          {
            "id": "finish-details",
            "type": "section",
            "title": "Account Summary",
            "componentIds": ["finishAccountCard"]
          },
          {
            "id": "finish-actions",
            "type": "section",
            "title": "Actions",
            "componentIds": ["openDashboardButton", "reviewSettingsButton"]
          }
        ]
      },
      "components": [
        {
          "id": "finishTitle",
          "type": "text",
          "adapterHint": "material.text",
          "props": {
            "text": "You're All Set!",
            "variant": "h4",
            "alignment": "center"
          }
        },
        {
          "id": "finishSummary",
          "type": "text",
          "adapterHint": "material.text",
          "props": {
            "text": "Your account has been configured successfully. Review your details below or jump straight to the dashboard.",
            "variant": "body1",
            "alignment": "center"
          }
        },
        {
          "id": "finishAccountCard",
          "type": "card",
          "adapterHint": "material.card",
          "props": {
            "title": "Account Information"
          },
          "bindings": {
            "data": {
              "name": "data.onboarding.accountName",
              "email": "data.onboarding.accountEmail",
              "organization": "data.onboarding.accountOrg",
              "tier": "data.onboarding.preferenceTier",
              "region": "data.onboarding.preferenceRegion",
              "notifications": "data.onboarding.preferenceNotifications"
            }
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.finishCard.aria",
            "tabIndex": 0,
            "role": "region",
            "keyboardNav": true,
            "focusOrder": 1
          }
        },
        {
          "id": "openDashboardButton",
          "type": "button",
          "adapterHint": "material.button",
          "props": {
            "label": "Open Dashboard",
            "variant": "contained",
            "color": "primary"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "event": "onOpenDashboard" }
            ]
          }
        },
        {
          "id": "reviewSettingsButton",
          "type": "button",
          "adapterHint": "material.button",
          "props": {
            "label": "Review Settings",
            "variant": "outlined",
            "color": "secondary"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "event": "onRestart" }
            ]
          }
        }
      ]
    }
  },
  "activeUiPageId": "welcome",
  "flowSchema": {
    "version": "1.0.0",
    "flowId": "onboarding-flow",
    "initialState": "welcome",
    "states": {
      "welcome": {
        "uiPageId": "welcome",
        "on": {
          "onGetStarted": {
            "target": "account-setup"
          }
        }
      },
      "account-setup": {
        "uiPageId": "account-setup",
        "on": {
          "onNext": {
            "target": "preferences",
            "guard": {
              "all": [
                {
                  "op": "exists",
                  "left": { "path": "data.onboarding.accountName" }
                },
                {
                  "op": "exists",
                  "left": { "path": "data.onboarding.accountEmail" }
                }
              ]
            }
          },
          "onBack": {
            "target": "welcome"
          }
        }
      },
      "preferences": {
        "uiPageId": "preferences",
        "on": {
          "onNext": {
            "target": "finish",
            "guard": {
              "op": "exists",
              "left": { "path": "data.onboarding.preferenceTier" }
            }
          },
          "onBack": {
            "target": "account-setup"
          }
        }
      },
      "finish": {
        "uiPageId": "finish",
        "on": {
          "onRestart": {
            "target": "welcome"
          }
        }
      }
    }
  },
  "rules": {
    "version": "1.0.0",
    "rules": [
      {
        "ruleId": "AccountFieldsValid",
        "description": "Enable next button when account name and email are both filled in",
        "priority": 90,
        "when": {
          "all": [
            {
              "op": "exists",
              "left": { "path": "data.onboarding.accountName" }
            },
            {
              "op": "exists",
              "left": { "path": "data.onboarding.accountEmail" }
            }
          ]
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.onboarding.nextEnabled",
            "value": true
          }
        ]
      },
      {
        "ruleId": "PreferencesValid",
        "description": "Enable next button when subscription tier is selected",
        "priority": 80,
        "when": {
          "op": "exists",
          "left": { "path": "data.onboarding.preferenceTier" }
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.onboarding.preferencesValid",
            "value": true
          }
        ]
      },
      {
        "ruleId": "DisableNextUnlessValid",
        "description": "Clear navigation flags when required fields are missing to prevent premature progression",
        "priority": 70,
        "when": {
          "not": {
            "all": [
              {
                "op": "exists",
                "left": { "path": "data.onboarding.accountName" }
              },
              {
                "op": "exists",
                "left": { "path": "data.onboarding.accountEmail" }
              },
              {
                "op": "exists",
                "left": { "path": "data.onboarding.preferenceTier" }
              }
            ]
          }
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.onboarding.nextEnabled",
            "value": false
          },
          {
            "type": "setContext",
            "path": "context.onboarding.preferencesValid",
            "value": false
          }
        ]
      }
    ]
  },
  "apiMappingsById": {
    "createAccount": {
      "version": "1.0.0",
      "apiId": "createAccount",
      "type": "rest",
      "method": "POST",
      "endpoint": "https://api.example.com/accounts",
      "requestMap": {
        "body": {
          "name": { "from": "data.onboarding.accountName" },
          "email": { "from": "data.onboarding.accountEmail" },
          "organization": { "from": "data.onboarding.accountOrg" },
          "tier": { "from": "data.onboarding.preferenceTier" },
          "region": { "from": "data.onboarding.preferenceRegion" },
          "notifications": { "from": "data.onboarding.preferenceNotifications" }
        },
        "headers": {
          "Content-Type": { "value": "application/json" }
        }
      },
      "responseMap": {
        "data": {
          "accountId": "response.accountId",
          "status": "response.status"
        },
        "context": {
          "lastRequestId": "response.requestId"
        }
      },
      "transforms": [],
      "errorHandling": {
        "map": {
          "400": "INVALID_ACCOUNT_DATA",
          "409": "ACCOUNT_ALREADY_EXISTS",
          "500": "SERVER_ERROR"
        },
        "retry": {
          "maxAttempts": 2,
          "backoffMs": 500
        }
      }
    }
  }
}
