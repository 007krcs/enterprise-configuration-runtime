    "account-setup": {
      "version": "1.0.0",
      "pageId": "account-setup",
      "layout": {
        "id": "root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "account-header",
            "type": "section",
            "title": "Account Details",
            "componentIds": ["accountSectionTitle"]
          },
          {
            "id": "account-form",
            "type": "section",
            "title": "Your Information",
            "componentIds": ["accountFullName", "accountEmail", "accountOrg"]
          },
          {
            "id": "account-actions",
            "type": "section",
            "title": "Actions",
            "componentIds": ["accountBackButton", "accountNextButton"]
          }
        ]
      },
      "components": [
        {
          "id": "accountSectionTitle",
          "type": "text",
          "adapterHint": "platform.alert",
          "props": {
            "title": "Account Details",
            "description": "Fill in your personal information to create your account",
            "intent": "primary"
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.accountSection.aria",
            "tabIndex": 0,
            "role": "heading",
            "keyboardNav": true,
            "focusOrder": 1
          }
        },
        {
          "id": "accountFullName",
          "type": "input",
          "adapterHint": "platform.textField",
          "props": {
            "label": "Full Name",
            "placeholder": "Enter your full name"
          },
          "i18n": {
            "labelKey": "onboarding.accountName.label",
            "placeholderKey": "onboarding.accountName.placeholder"
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.accountName"
            }
          },
          "validations": {
            "required": true,
            "min": 2,
            "max": 100
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.accountName.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 2
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 6 }
            }
          }
        },
        {
          "id": "accountEmail",
          "type": "input",
          "adapterHint": "platform.textField",
          "props": {
            "label": "Email Address",
            "placeholder": "you@example.com"
          },
          "i18n": {
            "labelKey": "onboarding.accountEmail.label",
            "placeholderKey": "onboarding.accountEmail.placeholder"
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.accountEmail"
            }
          },
          "validations": {
            "required": true,
            "regex": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.accountEmail.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 3
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 6 }
            }
          }
        },
        {
          "id": "accountOrg",
          "type": "input",
          "adapterHint": "platform.textField",
          "props": {
            "label": "Organization Name",
            "placeholder": "Your company or team name"
          },
          "i18n": {
            "labelKey": "onboarding.accountOrg.label",
            "placeholderKey": "onboarding.accountOrg.placeholder"
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.accountOrg"
            }
          },
          "validations": {
            "required": false
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.accountOrg.aria",
            "tabIndex": 0,
            "role": "textbox",
            "keyboardNav": true,
            "focusOrder": 4
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 6 }
            }
          }
        },
        {
          "id": "accountBackButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Back",
            "variant": "outline",
            "intent": "neutral",
            "size": "md"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onBack" } }
            ]
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.accountBack.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 5
          }
        },
        {
          "id": "accountNextButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Next",
            "variant": "solid",
            "intent": "primary",
            "size": "md"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onNext" } }
            ]
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.accountNext.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 6
          }
        }
      ]
    },
    "preferences": {
      "version": "1.0.0",
      "pageId": "preferences",
      "layout": {
        "id": "root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "preferences-header",
            "type": "section",
            "title": "Configure Preferences",
            "componentIds": ["preferencesSectionTitle"]
          },
          {
            "id": "preferences-form",
            "type": "section",
            "title": "Settings",
            "componentIds": ["preferenceTier", "preferenceRegion", "preferenceNotifications"]
          },
          {
            "id": "preferences-actions",
            "type": "section",
            "title": "Actions",
            "componentIds": ["preferencesBackButton", "preferencesNextButton"]
          }
        ]
      },
      "components": [
        {
          "id": "preferencesSectionTitle",
          "type": "text",
          "adapterHint": "platform.alert",
          "props": {
            "title": "Configure Preferences",
            "description": "Choose your subscription tier, region, and notification settings",
            "intent": "primary"
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.preferencesSection.aria",
            "tabIndex": 0,
            "role": "heading",
            "keyboardNav": true,
            "focusOrder": 1
          }
        },
        {
          "id": "preferenceTier",
          "type": "select",
          "adapterHint": "platform.select",
          "props": {
            "label": "Subscription Tier",
            "placeholder": "Select a tier",
            "options": [
              { "label": "Free", "value": "free" },
              { "label": "Pro", "value": "pro" },
              { "label": "Enterprise", "value": "enterprise" }
            ]
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.preferenceTier"
            }
          },
          "validations": {
            "required": true
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.preferenceTier.aria",
            "tabIndex": 0,
            "role": "listbox",
            "keyboardNav": true,
            "focusOrder": 2
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 6 }
            }
          }
        },
        {
          "id": "preferenceRegion",
          "type": "select",
          "adapterHint": "platform.select",
          "props": {
            "label": "Region",
            "placeholder": "Select a region",
            "options": [
              { "label": "Americas", "value": "americas" },
              { "label": "EMEA", "value": "emea" },
              { "label": "APAC", "value": "apac" }
            ]
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.preferenceRegion"
            }
          },
          "validations": {
            "required": false
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.preferenceRegion.aria",
            "tabIndex": 0,
            "role": "listbox",
            "keyboardNav": true,
            "focusOrder": 3
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 6 }
            }
          }
        },
        {
          "id": "preferenceNotifications",
          "type": "select",
          "adapterHint": "platform.select",
          "props": {
            "label": "Notifications",
            "placeholder": "Select notification preference",
            "options": [
              { "label": "Enabled", "value": "enabled" },
              { "label": "Disabled", "value": "disabled" }
            ]
          },
          "bindings": {
            "data": {
              "value": "data.onboarding.preferenceNotifications"
            }
          },
          "validations": {
            "required": false
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.preferenceNotifications.aria",
            "tabIndex": 0,
            "role": "listbox",
            "keyboardNav": true,
            "focusOrder": 4
          },
          "responsive": {
            "breakpoints": {
              "sm": { "columns": 12, "span": 12 },
              "md": { "columns": 12, "span": 6 }
            }
          }
        },
        {
          "id": "preferencesBackButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Back",
            "variant": "outline",
            "intent": "neutral",
            "size": "md"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onBack" } }
            ]
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.preferencesBack.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 5
          }
        },
        {
          "id": "preferencesNextButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Next",
            "variant": "solid",
            "intent": "primary",
            "size": "md"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onNext" } }
            ]
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.preferencesNext.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 6
          }
        }
      ]
    },
    "finish": {
      "version": "1.0.0",
      "pageId": "finish",
      "layout": {
        "id": "root",
        "type": "stack",
        "direction": "vertical",
        "children": [
          {
            "id": "finish-header",
            "type": "section",
            "title": "Complete",
            "componentIds": ["finishTitle", "finishSummary"]
          },
          {
            "id": "finish-details",
            "type": "section",
            "title": "Account Summary",
            "componentIds": ["finishAccountTable"]
          },
          {
            "id": "finish-actions",
            "type": "section",
            "title": "Actions",
            "componentIds": ["openDashboardButton", "reviewSettingsButton"]
          }
        ]
      },
      "components": [
        {
          "id": "finishTitle",
          "type": "text",
          "adapterHint": "platform.alert",
          "props": {
            "title": "You're All Set!",
            "intent": "success"
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.finish.title.aria",
            "tabIndex": 0,
            "role": "heading",
            "keyboardNav": true,
            "focusOrder": 1
          }
        },
        {
          "id": "finishSummary",
          "type": "text",
          "adapterHint": "platform.alert",
          "props": {
            "title": "Account Configured",
            "description": "Your account has been configured successfully. Review your details below or jump straight to the dashboard.",
            "intent": "neutral"
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.finish.summary.aria",
            "tabIndex": 0,
            "role": "status",
            "keyboardNav": true,
            "focusOrder": 2
          }
        },
        {
          "id": "finishAccountTable",
          "type": "table",
          "adapterHint": "platform.table",
          "props": {
            "columns": [
              { "field": "field", "headerKey": "onboarding.finish.table.field" },
              { "field": "value", "headerKey": "onboarding.finish.table.value" }
            ],
            "rows": []
          },
          "bindings": {
            "data": {
              "rows": "data.onboarding.summaryRows"
            }
          },
          "i18n": {
            "labelKey": "onboarding.finish.table.label"
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.finish.table.aria",
            "tabIndex": 0,
            "role": "table",
            "keyboardNav": true,
            "focusOrder": 3
          }
        },
        {
          "id": "openDashboardButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Open Dashboard",
            "variant": "solid",
            "intent": "primary",
            "size": "lg"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onOpenDashboard" } }
            ]
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.finish.openDashboard.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 4
          }
        },
        {
          "id": "reviewSettingsButton",
          "type": "button",
          "adapterHint": "platform.button",
          "props": {
            "label": "Review Settings",
            "variant": "outline",
            "intent": "neutral",
            "size": "md"
          },
          "events": {
            "onClick": [
              { "type": "emitEvent", "payload": { "event": "onRestart" } }
            ]
          },
          "accessibility": {
            "ariaLabelKey": "onboarding.finish.reviewSettings.aria",
            "tabIndex": 0,
            "role": "button",
            "keyboardNav": true,
            "focusOrder": 5
          }
        }
      ]
    }
  },
  "activeUiPageId": "welcome",
  "flowSchema": {
    "version": "1.0.0",
    "flowId": "onboarding-flow",
    "initialState": "welcome",
    "states": {
      "welcome": {
        "uiPageId": "welcome",
        "on": {
          "onGetStarted": {
            "target": "account-setup"
          }
        }
      },
      "account-setup": {
        "uiPageId": "account-setup",
        "on": {
          "onNext": {
            "target": "preferences",
            "guard": {
              "all": [
                {
                  "op": "exists",
                  "left": { "path": "data.onboarding.accountName" }
                },
                {
                  "op": "exists",
                  "left": { "path": "data.onboarding.accountEmail" }
                }
              ]
            }
          },
          "onBack": {
            "target": "welcome"
          }
        }
      },
      "preferences": {
        "uiPageId": "preferences",
        "on": {
          "onNext": {
            "target": "finish",
            "guard": {
              "op": "exists",
              "left": { "path": "data.onboarding.preferenceTier" }
            }
          },
          "onBack": {
            "target": "account-setup"
          }
        }
      },
      "finish": {
        "uiPageId": "finish",
        "on": {
          "onRestart": {
            "target": "welcome"
          }
        }
      }
    }
  },
  "rules": {
    "version": "1.0.0",
    "rules": [
      {
        "ruleId": "AccountFieldsValid",
        "description": "Enable next button when account name and email are both filled in",
        "priority": 90,
        "when": {
          "all": [
            {
              "op": "exists",
              "left": { "path": "data.onboarding.accountName" }
            },
            {
              "op": "exists",
              "left": { "path": "data.onboarding.accountEmail" }
            }
          ]
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.onboarding.nextEnabled",
            "value": true
          }
        ]
      },
      {
        "ruleId": "PreferencesValid",
        "description": "Enable next button when subscription tier is selected",
        "priority": 80,
        "when": {
          "op": "exists",
          "left": { "path": "data.onboarding.preferenceTier" }
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.onboarding.preferencesValid",
            "value": true
          }
        ]
      },
      {
        "ruleId": "DisableNextUnlessValid",
        "description": "Clear navigation flags when required fields are missing to prevent premature progression",
        "priority": 70,
        "when": {
          "not": {
            "all": [
              {
                "op": "exists",
                "left": { "path": "data.onboarding.accountName" }
              },
              {
                "op": "exists",
                "left": { "path": "data.onboarding.accountEmail" }
              },
              {
                "op": "exists",
                "left": { "path": "data.onboarding.preferenceTier" }
              }
            ]
          }
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.onboarding.nextEnabled",
            "value": false
          },
          {
            "type": "setContext",
            "path": "context.onboarding.preferencesValid",
            "value": false
          }
        ]
      }
    ]
  },
  "apiMappingsById": {
    "createAccount": {
      "version": "1.0.0",
      "apiId": "createAccount",
      "type": "rest",
      "method": "POST",
      "endpoint": "https://api.example.com/accounts",
      "requestMap": {
        "body": {
          "name": { "from": "data.onboarding.accountName" },
          "email": { "from": "data.onboarding.accountEmail" },
          "organization": { "from": "data.onboarding.accountOrg" },
          "tier": { "from": "data.onboarding.preferenceTier" },
          "region": { "from": "data.onboarding.preferenceRegion" },
          "notifications": { "from": "data.onboarding.preferenceNotifications" }
        },
        "headers": {
          "Content-Type": { "value": "application/json" }
        }
      },
      "responseMap": {
        "data": {
          "accountId": "response.accountId",
          "status": "response.status"
        },
        "context": {
          "lastRequestId": "response.requestId"
        }
      },
      "transforms": [],
      "errorHandling": {
        "map": {
          "400": "INVALID_ACCOUNT_DATA",
          "409": "ACCOUNT_ALREADY_EXISTS",
          "500": "SERVER_ERROR"
        },
        "retry": {
          "maxAttempts": 2,
          "backoffMs": 500
        }
      }
    }
  }
}
