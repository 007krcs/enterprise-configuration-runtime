          "tabIndex": 0,
          "role": "table",
          "keyboardNav": true,
          "focusOrder": 3
        }
      },
      {
        "id": "revenueChart",
        "type": "chart",
        "adapterHint": "highcharts.chart",
        "props": {
          "series": []
        },
        "i18n": {
          "labelKey": "runtime.revenue.chart.label"
        },
        "bindings": {
          "data": {
            "series": "data.revenueSeries"
          }
        },
        "accessibility": {
          "ariaLabelKey": "runtime.revenue.chart.aria",
          "tabIndex": 0,
          "role": "img",
          "keyboardNav": true,
          "focusOrder": 4
        }
      },
      {
        "id": "customViz",
        "type": "custom",
        "adapterHint": "d3.custom",
