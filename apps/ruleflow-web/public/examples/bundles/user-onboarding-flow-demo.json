  "activeUiPageId": "onboarding-flow",
  "flowSchema": {
    "version": "1.0.0",
    "flowId": "onboarding-flow",
    "initialState": "welcome",
    "states": {
      "welcome": {
        "uiPageId": "onboarding-flow",
        "on": {
          "next": {
            "target": "profile",
            "guard": {
              "op": "eq",
              "left": {
                "path": "data.acceptedTerms"
              },
              "right": {
                "value": true
              }
            }
          }
        }
      },
      "profile": {
        "uiPageId": "onboarding-flow",
        "on": {
          "back": {
            "target": "welcome"
          },
          "next": {
            "target": "verify",
            "guard": {
              "op": "eq",
              "left": {
                "path": "data.formValid"
              },
              "right": {
                "value": true
              }
            }
          }
        }
      },
      "verify": {
        "uiPageId": "onboarding-flow",
        "on": {
          "back": {
            "target": "profile"
          },
          "submit": {
            "target": "complete",
            "guard": {
              "op": "eq",
              "left": {
                "path": "data.readyToSubmit"
              },
              "right": {
                "value": true
              }
            },
            "actions": [
              "evaluateRules",
              "callApi"
            ],
            "apiId": "verifyIdentity"
          }
        }
      },
      "complete": {
        "uiPageId": "onboarding-flow",
        "on": {
          "back": {
            "target": "verify"
          }
        }
      }
    }
  },
  "rules": {
    "version": "1.0.0",
    "rules": [
      {
        "ruleId": "US_ADMIN_DISCOUNT",
        "description": "Apply admin approval for high-risk onboarding requests",
        "priority": 100,
        "scope": {
          "countries": [
            "US"
          ],
          "roles": [
            "admin"
          ]
        },
        "when": {
          "op": "gt",
          "left": {
            "path": "data.orderTotal"
          },
          "right": {
            "value": 1000
          }
        },
        "actions": [
          {
            "type": "setField",
            "path": "data.discount",
            "value": 0.1
          },
          {
            "type": "emitEvent",
            "event": "discountApplied",
            "payload": {
              "level": "admin"
            }
          }
        ]
      },
      {
        "ruleId": "EU_GDPR_NOTICE",
        "description": "Flag GDPR notices for EU hires",
        "priority": 50,
        "scope": {
          "countries": [
            "DE",
            "FR",
            "ES"
          ],
          "roles": [
            "user",
            "admin"
          ]
        },
        "when": {
          "op": "exists",
          "left": {
            "path": "context.locale"
          }
        },
        "actions": [
          {
            "type": "setContext",
            "path": "context.gdprNotice",
            "value": true
          }
        ]
      },
      {
        "ruleId": "BLOCK_GUEST_RESTRICTED",
        "description": "Prevent guests from opening onboarding artifacts",
        "priority": 10,
        "scope": {
          "roles": [
            "guest"
          ]
        },
        "when": {
          "op": "eq",
          "left": {
            "path": "data.restricted"
          },
          "right": {
            "value": true
          }
        },
        "actions": [
          {
            "type": "throwError",
            "message": "Guest access not permitted",
            "code": "GUEST_BLOCK"
          }
        ]
      }
    ]
  },
  "apiMappingsById": {
    "verifyIdentity": {
      "version": "1.0.0",
      "apiId": "verifyIdentity",
      "type": "rest",
      "method": "POST",
      "endpoint": "https://api.example.com/verify",
      "requestMap": {
        "body": {
          "userId": {
            "from": "context.userId"
          },
          "profileStatus": {
            "from": "data.orderTotal"
          },
          "locale": {
            "from": "context.locale"
          }
        },
        "headers": {
          "authorization": {
            "from": "context.permissions[0]"
          }
        }
      },
      "responseMap": {
        "data": {
          "verified": "response.status"
        }
      },
      "transforms": [],
      "errorHandling": {
        "map": {
          "401": "UNAUTHORIZED"
        },
        "retry": {
          "maxAttempts": 1,
          "backoffMs": 500
        }
      }
    }
  }
}