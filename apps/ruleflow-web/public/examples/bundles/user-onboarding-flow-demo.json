        "responsive": {
          "breakpoints": {
            "sm": {
              "columns": 12,
              "span": 12
            },
            "md": {
              "columns": 12,
              "span": 6
            }
          }
        }
      },
      {
        "id": "ordersTable",
        "type": "table",
        "adapterHint": "aggrid.table",
        "props": {
          "columns": [
            {
              "field": "orderId",
              "headerKey": "runtime.orders.table.columns.orderId"
            },
            {
              "field": "customer",
              "headerKey": "runtime.orders.table.columns.customer"
            },
            {
              "field": "total",
